# See wiki/dotenv-bot-secret.md

# Telegram bot token
BOT_TOKEN=<bot-token>

# LMS API
LMS_API_BASE_URL=<lms-api-base-url>
LMS_API_KEY=<lms-api-key>

# LLM API
LLM_API_MODEL=coder-model
LLM_API_KEY=<llm-api-key>
LLM_API_BASE_URL=<llm-api-base-url>

# Qwen Code API (optional, for advanced features)
QWEN_CODE_API_URL=<qwen-code-api-url>
